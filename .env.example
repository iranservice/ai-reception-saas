# ============================================================
# AI Reception SaaS — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------
# Database (Prisma)
# ------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/ai_reception_saas?schema=public"

# ------------------------------------
# Next.js
# ------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------
# Auth (placeholder — configure in Phase 1)
# ------------------------------------
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="your-secret-here"

# ------------------------------------
# AI Runtime (placeholder — configure in Phase 5)
# ------------------------------------
# OPENAI_API_KEY="sk-..."
# AI_PROVIDER="openai"

# ------------------------------------
# Integrations (placeholder — configure per channel phase)
# ------------------------------------
